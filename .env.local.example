# --- Supabase project ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser. Used for all dashboard/explorer/schema reads.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI query executor (analytics_readonly role) ---
# Created by running supabase/migrations/001_analytics_readonly_role.sql yourself
# in the Supabase SQL editor, then grab the *pooled* (Supavisor, transaction mode)
# connection string for that role from Project Settings -> Database -> Connection pooling.
SUPABASE_READONLY_DB_URL=postgresql://analytics_readonly:your-password@your-project-pooler.supabase.com:6543/postgres

# --- Weekly schema-cache refresh cron (Vercel Cron -> /api/schema-cache/refresh) ---
CRON_SECRET=any-random-string

# --- One-off schema introspection only (NOT read by the app at runtime) ---
# Used only by `npm run introspect-schema`. Any role with read access to
# information_schema/pg_catalog works, e.g. the default postgres connection
# string from Project Settings -> Database -> Connection string.
# Delete this line once introspection is done; it is not part of the deployed app.
INTROSPECTION_DB_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
