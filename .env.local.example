# --- Supabase project ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser. Used for all dashboard/explorer/schema reads.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI query executor (analytics_readonly role) ---
# Created by running supabase/migrations/001_analytics_readonly_role.sql yourself
# in the Supabase SQL editor, then grab the *pooled* (Supavisor, transaction mode)
# connection string for that role from Project Settings -> Database -> Connection pooling.
SUPABASE_READONLY_DB_URL=postgresql://analytics_readonly:your-password@your-project-pooler.supabase.com:6543/postgres

# --- Weekly schema-cache refresh cron (Vercel Cron -> /api/schema-cache/refresh) ---
# Also gates the daily Telegram notify cron below.
CRON_SECRET=any-random-string

# --- Telegram daily "new data fetched" bot ---
# Token from @BotFather (see README "Telegram daily updates" for full setup).
TELEGRAM_BOT_TOKEN=123456:your-bot-token
# Shared password anyone messaging the bot must send once to subscribe.
TELEGRAM_BOT_PASSWORD=choose-a-password
# Random string you also pass as secret_token when calling setWebhook, so
# /api/telegram/webhook can verify requests actually came from Telegram.
TELEGRAM_WEBHOOK_SECRET=any-random-string

# --- Groq (Telegram bot free-text question classifier only) ---
# Optional: without these, the bot still works via its button menu, it just
# can't handle typed free-text questions. Reused from the removed AI Query
# panel, but scoped very differently now — see src/lib/telegram/intents.ts.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Maps Geocoding API (New User Locations page + Telegram button) ---
# Reverse-geocodes new-user signup coordinates to "City, State". Create a key
# at console.cloud.google.com -> APIs & Services -> Credentials, with the
# Geocoding API enabled on that project (requires billing enabled; results
# are cached per coordinate in analytics_geocode_cache so repeat locations
# don't re-bill). Without this set, locations show as "Unknown location".
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- One-off schema introspection only (NOT read by the app at runtime) ---
# Used only by `npm run introspect-schema`. Any role with read access to
# information_schema/pg_catalog works, e.g. the default postgres connection
# string from Project Settings -> Database -> Connection string.
# Delete this line once introspection is done; it is not part of the deployed app.
INTROSPECTION_DB_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
